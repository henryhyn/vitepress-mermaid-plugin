{
  "name": "vitepress-mermaid-plugin",
  "version": "3.0.0",
  "description": "Add mermaid support for Vitepress",
  "type": "module",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:serve": "vitepress serve docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/henryhyn/vitepress-mermaid-plugin.git"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/vitepress-mermaid-plugin.umd.js",
  "module": "./dist/vitepress-mermaid-plugin.es.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vitepress-mermaid-plugin.es.mjs",
      "require": "./dist/vitepress-mermaid-plugin.umd.js"
    },
    "./Mermaid.vue": "./dist/Mermaid.vue"
  },
  "keywords": [
    "vitepress",
    "mermaid"
  ],
  "author": "Emerson Bottero",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/henryhyn/vitepress-mermaid-plugin/issues"
  },
  "homepage": "https://github.com/henryhyn/vitepress-mermaid-plugin#readme",
  "peerDependencies": {
    "mermaid": "10 || 11",
    "vitepress": "^1.0.0 || ^1.0.0-alpha || ^2.0.0 || ^2.0.0-alpha"
  },
  "optionalDependencies": {
    "@mermaid-js/mermaid-mindmap": "^9.3.0"
  },
  "devDependencies": {
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-static-copy": "^4.0.0",
    "vitepress": "^2.0.0-alpha",
    "vite": "7"
  }
}
